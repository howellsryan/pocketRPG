{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "jsx": "react",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "allowJs": true,
    "outDir": "./dist_tmp",
    "rootDir": "./src",
    "skipLibCheck": true,
    "noEmit": false,
    "declaration": false,
    "esModuleInterop": true
  },
  "include": ["src/**/*"]
}
